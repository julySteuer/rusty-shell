char        =  { ASCII_ALPHANUMERIC | "." | "/" }
whitespaces = _{ " "+ }
whitespaces_opt = _{ " "* }
NAME        = @{ char+ }
ARGUMENT    = @{ whitespaces ~ char+ }
// Has To be trimmed
CALL        = { NAME ~ ARGUMENT* }
PIPE        = { "|" ~ whitespaces_opt ~ CALL }
REDIRECTION = { ">" ~ whitespaces_opt ~ CALL }
EXPR        = { ((PIPE | REDIRECTION | CALL) ~ whitespaces_opt)+ }